{
  "buildCommand": "node build-alt-domain.mjs",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/leseprobe", "destination": "/leseprobe.html" }
  ],
  "headers": [
    {
      "source": "/:all*(webp|jpg|jpeg|png|gif|svg|ico|avif|woff|woff2|ttf|otf|pdf|mp4|webm|mov|m4v|ogg|ogv)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:all*(css|js|mjs)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
